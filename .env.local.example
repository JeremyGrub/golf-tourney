# Copy this to `.env.local` once you've created a Supabase project.
# Find these values at: Supabase dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Canonical public origin for this deployment (scheme + host, no trailing /).
# Used for magic-link email redirects, OG image metadataBase, and any other
# URL that has to leave the server. On Vercel, set this in the project's
# Environment Variables for Production — previews will auto-fall back to
# VERCEL_URL, and local dev to http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://thru.golf

# Optional — only needed for scripted admin tasks (e.g. seed scripts).
# Never commit or expose in client code.
# SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
